// User template for Java

class Solution {
  public:
    void replaceElements(vector<int>& arr) {
        int prev = arr[0];
        for(int i=0;i<arr.size()-1;i++)
        {
            int temp = arr[i];
            arr[i] = prev ^ arr[i+1];
            prev = temp;
        }
        arr[arr.size()-1] ^= prev;
    }
};

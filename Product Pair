// User template for Java

class Solution {
  public:
    bool isProduct(vector<int>& arr, long long target) {
        unordered_set<int> st;
        for(auto it : arr)
        {
            if((it && target%abs(it)==0 && st.find(target/it)!=st.end()) || (!it && !target))
            return true;
            st.insert(it);
        }
        return false;
    }
};

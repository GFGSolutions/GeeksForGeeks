// User Template For C++

class Solution {
  public:
    void pre_suc(Node* root , Node* &pre,Node* &succ,int key,bool &found_pre)
    {
        if(root == NULL)
        {
            return;
        }
        pre_suc(root -> left,pre,succ,key,found_pre);    
        if(root -> data < key)
        {
            pre -> data = root -> data;
        }
        else if(found_pre == false && root -> data > key )
        {
            succ-> data = root ->data;
            found_pre = true;
        }
        pre_suc(root -> right , pre,succ,key,found_pre);
    }
    vector<Node*> findPreSuc(Node* root, int key) 
    {
        vector<Node*> ans;
        Node* pre = new Node(-1);
        Node* succ = new Node(-1);
        bool found = false;
        pre_suc(root,pre,succ,key,found);
        ans.push_back(pre);
        ans.push_back(succ);
        return ans;
    }
};

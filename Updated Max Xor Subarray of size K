class Solution {
  public:
    int maxSubarrayXOR(vector<int>& arr, int k) {
        int xorval = 0, i=0;
        for(i=0; i<k; i++)
        {
            xorval^=arr[i];
        }
        int ans = xorval;
        for(i=k; i<arr.size(); i++)
        {
            xorval^=(arr[i-k]^arr[i]);
            ans = max(ans, xorval);
        }
        return ans;
    }
};
